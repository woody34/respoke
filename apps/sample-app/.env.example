# Required for Descope authentication
REACT_APP_DESCOPE_PROJECT_ID="YOUR PROJECT ID"

# Point the SDK at the local emulator (required for emulator testing)
REACT_APP_DESCOPE_BASE_URL="http://localhost:4500"
REACT_APP_DESCOPE_BASE_STATIC_URL="http://localhost:4500"

# Optional: override the default sign-up-or-in flow
REACT_APP_DESCOPE_SIGN_IN_FLOW_ID="sign-up-or-in"

# For running e2e tests against the emulator
EMULATOR_PROJECT_ID="emulator-project"
EMULATOR_MANAGEMENT_KEY="emulator-key"
EMULATOR_BASE_URL="http://localhost:4500"